DISCORD_BOT_TOKEN=

# Blackboard cookie refresh portal (served at /blackboard-login on port 3002)
BLACKBOARD_REFRESH_PIN=1234   # Change this to your preferred 4-digit PIN

# Google OAuth credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth token path (used by budget tracker for Gmail + Sheets)
# Run scripts/gcal-auth.mjs to generate this token with all required scopes.
GOOGLE_TOKEN_PATH=scripts/.gcal-token.json

# OpenWeatherMap API key (used by morning briefing for weather data)
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Twilio SMS channel (primary interface)
TWILIO_ACCOUNT_SID=        # From console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=         # From console.twilio.com → Account Info
TWILIO_FROM_NUMBER=        # Your Twilio number in E.164 format, e.g. +15551234567
SMS_MY_NUMBER=             # Your personal phone number in E.164 format, e.g. +15559876543
SMS_WEBHOOK_PORT=3002      # Local port for the SMS webhook HTTP server
SMS_WEBHOOK_URL=           # Public URL Twilio posts to, e.g. https://abc.ngrok.io
                           # Leave empty during local dev (skips signature validation)

# Site credentials for browser automation (stored securely per-group via `pw creds set`)
# The agent stores credentials in groups/<name>/credentials.json, not here.
# Add them interactively by asking the agent:
#   "Store my GitHub credentials: username=alice@example.com password=... url=https://github.com/login"
# Or directly via Bash in the container workspace:
#   pw creds set github alice@example.com MyP@ssw0rd https://github.com/login
